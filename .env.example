NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Auth
# Configure Supabase Site URL to NEXT_PUBLIC_APP_URL and add redirect URLs:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/update-password
# https://your-domain.vercel.app/auth/callback
# https://your-domain.vercel.app/auth/update-password
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe Checkout
# Use test keys locally and live keys only on production hosting.
# Add webhook endpoint: https://your-domain.vercel.app/api/stripe/webhook
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PLUS=price_xxx
STRIPE_PRICE_PRO=price_xxx
